# Cloudflare Calls (SFU) — required
CLOUDFLARE_APP_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare TURN — required
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_KEY_API_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379/0

# WebRTC Redis pool size (default: 10)
# WEBRTC_REDIS_POOL_SIZE=10

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=generate_with_bin_rails_secret

# PostgreSQL (optional — defaults to local socket)
# DATABASE_URL=postgres://user:pass@localhost:5432/konexzero_development
